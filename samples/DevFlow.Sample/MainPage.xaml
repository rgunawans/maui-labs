<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DevFlow.Sample.MainPage"
             Title="My Todos">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Settings"
                     IconImageSource="settings.png"
                     AutomationId="SettingsToolbarItem"
                     Clicked="OnSettingsClicked" />
    </ContentPage.ToolbarItems>
    <ContentPage.BackgroundColor>
        <AppThemeBinding Light="#F5F5F5" Dark="#1C1B1F" />
    </ContentPage.BackgroundColor>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Padding="0,8,0,16">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="📝 My Todos"
                       FontSize="28"
                       FontAttributes="Bold"
                       AutomationId="HeaderLabel">
                    <Label.TextColor>
                        <AppThemeBinding Light="#1C1B1F" Dark="#E6E1E5" />
                    </Label.TextColor>
                </Label>
                <Button Grid.Column="1"
                        Text="Show Modal"
                        FontSize="12"
                        CornerRadius="8"
                        Padding="12,4"
                        VerticalOptions="Center"
                        AutomationId="ShowModalButton"
                        Clicked="OnShowModal">
                    <Button.BackgroundColor>
                        <AppThemeBinding Light="#6750A4" Dark="#D0BCFF" />
                    </Button.BackgroundColor>
                    <Button.TextColor>
                        <AppThemeBinding Light="#FFFFFF" Dark="#381E72" />
                    </Button.TextColor>
                </Button>
            </Grid>
            <Label x:Name="CountLabel"
                   Text="0 items"
                   FontSize="14"
                   AutomationId="CountLabel">
                <Label.TextColor>
                    <AppThemeBinding Light="#49454F" Dark="#CAC4D0" />
                </Label.TextColor>
            </Label>
        </VerticalStackLayout>

        <!-- Todo List -->
        <CollectionView x:Name="TodoList"
                        Grid.Row="1"
                        AutomationId="TodoList"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No todos yet. Add one below!"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16">
                    <Label.TextColor>
                        <AppThemeBinding Light="#49454F" Dark="#CAC4D0" />
                    </Label.TextColor>
                </Label>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Add Todo -->
        <Border Grid.Row="2"
                StrokeShape="RoundRectangle 12"
                Padding="12"
                Margin="0,8,0,0"
                AutomationId="AddTodoBorder">
            <Border.BackgroundColor>
                <AppThemeBinding Light="#FFFFFF" Dark="#2B2930" />
            </Border.BackgroundColor>
            <Border.Stroke>
                <AppThemeBinding Light="#E0E0E0" Dark="#49454F" />
            </Border.Stroke>
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="8" RowSpacing="6">
                <Entry x:Name="NewTodoEntry"
                       Placeholder="What needs to be done?"
                       FontSize="16"
                       BackgroundColor="Transparent"
                       AutomationId="NewTodoEntry"
                       ReturnType="Next">
                    <Entry.TextColor>
                        <AppThemeBinding Light="#1C1B1F" Dark="#E6E1E5" />
                    </Entry.TextColor>
                    <Entry.PlaceholderColor>
                        <AppThemeBinding Light="#79747E" Dark="#938F99" />
                    </Entry.PlaceholderColor>
                </Entry>
                <Entry x:Name="NewDescriptionEntry"
                       Grid.Row="1"
                       Placeholder="Description (optional)"
                       FontSize="13"
                       BackgroundColor="Transparent"
                       AutomationId="NewDescriptionEntry"
                       ReturnType="Done"
                       Completed="OnAddTodo">
                    <Entry.TextColor>
                        <AppThemeBinding Light="#49454F" Dark="#CAC4D0" />
                    </Entry.TextColor>
                    <Entry.PlaceholderColor>
                        <AppThemeBinding Light="#79747E" Dark="#938F99" />
                    </Entry.PlaceholderColor>
                </Entry>
                <Button x:Name="AddButton"
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        Text="Add"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        Padding="16,0"
                        VerticalOptions="Center"
                        AutomationId="AddButton"
                        Clicked="OnAddTodo">
                    <Button.BackgroundColor>
                        <AppThemeBinding Light="#6750A4" Dark="#D0BCFF" />
                    </Button.BackgroundColor>
                    <Button.TextColor>
                        <AppThemeBinding Light="#FFFFFF" Dark="#381E72" />
                    </Button.TextColor>
                </Button>
            </Grid>
        </Border>
    </Grid>

</ContentPage>
