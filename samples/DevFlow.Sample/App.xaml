<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:DevFlow.Sample"
             x:Class="DevFlow.Sample.App">
    <Application.Resources>
        <ResourceDictionary>

            <!--
                For information about styling .NET MAUI pages
                please refer to the documentation:
                https://go.microsoft.com/fwlink/?linkid=2282329
            -->

            <Style x:Key="DialogButton" TargetType="Button">
                <Setter Property="BackgroundColor">
                    <Setter.Value>
                        <AppThemeBinding Light="#6750A4" Dark="#D0BCFF" />
                    </Setter.Value>
                </Setter>
                <Setter Property="TextColor">
                    <Setter.Value>
                        <AppThemeBinding Light="#FFFFFF" Dark="#381E72" />
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
