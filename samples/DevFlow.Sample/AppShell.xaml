<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:DevFlow.Sample"
       x:Class="DevFlow.Sample.AppShell"
       Title="MauiTodo">

    <ShellContent Title="Native" Route="native"
                  ContentTemplate="{DataTemplate local:MainPage}" />
    <ShellContent Title="Blazor" Route="blazor"
                  ContentTemplate="{DataTemplate local:BlazorTodoPage}" />
    <ShellContent Title="Multi-Blazor" Route="multiblazor"
                  ContentTemplate="{DataTemplate local:MultiBlazorPage}" />
    <ShellContent Title="Interactions" Route="interactions"
                  ContentTemplate="{DataTemplate local:InteractionTestPage}" />
    <ShellContent Title="Dialogs" Route="dialogs"
                  ContentTemplate="{DataTemplate local:DialogTestPage}" />
    <ShellContent Title="Network" Route="network"
                  ContentTemplate="{DataTemplate local:NetworkTestPage}" />

</Shell>
