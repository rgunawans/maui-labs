<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-macos</TargetFramework>
    <SupportedOSPlatformVersion>14.0</SupportedOSPlatformVersion>
    <RootNamespace>Microsoft.Maui.Platforms.MacOS.Essentials</RootNamespace>
    <AssemblyName>Microsoft.Maui.Platforms.MacOS.Essentials</AssemblyName>
    <PackageId>Microsoft.Maui.Platforms.MacOS.Essentials</PackageId>
    <Version>$(PlatformMauiMacOSEssentialsVersion)</Version>
    <Description>macOS AppKit implementations of Microsoft.Maui.Essentials APIs (AppInfo, Battery, Geolocation, Preferences, SecureStorage, etc.). Companion to Microsoft.Maui.Platforms.MacOS.</Description>
    <PackageTags>maui;macos;appkit;essentials;dotnet;cross-platform</PackageTags>
    <IsPackable>true</IsPackable>
    <IsShipping>true</IsShipping>
    <IsTrimmable>true</IsTrimmable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Maui.Essentials" />
    <PackageReference Include="Microsoft.Maui.Core" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="ILLink.Descriptors.xml">
      <LogicalName>ILLink.Descriptors.xml</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
