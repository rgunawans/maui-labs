@page "/"

<h1>Hello from Blazor on WPF!</h1>

<p>This is a Blazor Hybrid page running inside a .NET MAUI app on Windows via WebView2.</p>

<p>Current count: @currentCount</p>

<button @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
