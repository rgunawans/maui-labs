<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="../Version.props" />

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <DefineConstants Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(DefineConstants);WINDOWS_BUILD</DefineConstants>

    <PackageId>Microsoft.Maui.DevFlow.Driver</PackageId>
    <Description>Driver library for connecting to Microsoft.Maui.DevFlow Agent and orchestrating MAUI app automation.</Description>
    <PackageTags>maui;automation;testing;driver</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" />
    <PackageReference Include="Interop.UIAutomationClient" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
  </ItemGroup>

</Project>
