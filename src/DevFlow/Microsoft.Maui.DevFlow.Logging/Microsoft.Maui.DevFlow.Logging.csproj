<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="../Version.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>

    <PackageId>Microsoft.Maui.DevFlow.Logging</PackageId>
    <IsShipping>true</IsShipping>
    <Description>Buffered rotating JSONL file logger for Microsoft.Maui.DevFlow. No MAUI dependency.</Description>
    <PackageTags>logging;jsonl;rotating</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.Maui.DevFlow.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

</Project>
