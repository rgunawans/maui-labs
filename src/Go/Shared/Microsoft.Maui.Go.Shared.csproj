<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Microsoft.Maui.Go</RootNamespace>
    <Description>Shared wire protocol for Comet Go dev server and companion app</Description>
    <!-- Go projects are dev-time tools, not AOT-published -->
    <IsAotCompatible>false</IsAotCompatible>
    <EnableTrimAnalyzer>false</EnableTrimAnalyzer>
    <EnableAotAnalyzer>false</EnableAotAnalyzer>
    <!-- Suppress IL warnings that propagate to consuming projects (CLI) during ILC/AOT -->
    <NoWarn>$(NoWarn);IL2026;IL3050</NoWarn>
  </PropertyGroup>
</Project>
