<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiControlsGallery.Pages.PickersPage"
             Title="Pickers &amp; Search">
    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="24">

            <!-- DatePicker -->
            <Label Text="DatePicker" FontSize="16" FontAttributes="Bold" TextColor="CornflowerBlue" />
            <DatePicker x:Name="DemoDatePicker" DateSelected="OnDateSelected" />
            <Label x:Name="DateLabel" Text="Selected date: (none)" FontSize="14" />
            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- TimePicker -->
            <Label Text="TimePicker" FontSize="16" FontAttributes="Bold" TextColor="CornflowerBlue" />
            <TimePicker x:Name="DemoTimePicker" />
            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Picker (Dropdown) -->
            <Label Text="Picker (Dropdown)" FontSize="16" FontAttributes="Bold" TextColor="CornflowerBlue" />
            <Picker x:Name="ColorPicker" Title="Pick a color" SelectedIndexChanged="OnPickerSelected">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Red</x:String>
                        <x:String>Green</x:String>
                        <x:String>Blue</x:String>
                        <x:String>Orange</x:String>
                        <x:String>Purple</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Label x:Name="PickerLabel" Text="Selected: (none)" FontSize="14" />
            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- SearchBar -->
            <Label Text="SearchBar" FontSize="16" FontAttributes="Bold" TextColor="CornflowerBlue" />
            <SearchBar x:Name="DemoSearchBar" Placeholder="Search fruits..." TextChanged="OnSearchTextChanged" />
            <Label x:Name="SearchResultLabel" Text="Search results will appear here..." FontSize="14" TextColor="Gray" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
